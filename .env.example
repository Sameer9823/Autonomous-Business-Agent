# TinyFish Web Agent API
TINYFISH_API_KEY=your_tinyfish_api_key_here

# Google Gemini AI
GEMINI_API_KEY=your_gemini_api_key_here

# MongoDB
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/autobizops

# NextAuth — REQUIRED for authentication
NEXTAUTH_SECRET=your-super-secret-key-min-32-chars-change-this
NEXTAUTH_URL=http://localhost:3000
# On Vercel set NEXTAUTH_URL to: https://your-app.vercel.app
